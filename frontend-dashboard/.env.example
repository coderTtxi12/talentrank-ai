# Frontend Environment Variables
# Copy this file to .env and adjust values as needed

# API Base URL
# Development: Leave as /api (uses Vite proxy)
# Production: Full URL like https://api.loan.example.com
VITE_API_URL=/api/v1

# Socket.IO — origen del API (Engine.IO solo usa namespace "/" por defecto; no pongas /candidates en la URL).
# Ej. Docker host: VITE_SOCKET_URL=http://localhost:8000 (o el puerto de API_PORT)
VITE_SOCKET_URL=
VITE_SOCKET_PORT=8000
VITE_SOCKET_PATH=/socket.io

# Vite Dev Server Proxy Targets (only for development)
# These are used by Vite's proxy in vite.config.ts
VITE_API_PROXY_TARGET=http://localhost:8000
VITE_SOCKET_PROXY_TARGET=http://localhost:8000

# App Configuration
VITE_APP_ENV=development
VITE_APP_NAME=Loan System
VITE_ENABLE_DEBUG=true
