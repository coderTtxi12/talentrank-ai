# =============================================================================
# Backend - Variables consumidas por la app (Pydantic Settings) y libs.
# =============================================================================
# Copia a backend/.env y rellena los secretos.
#
# Variables de orquestación (POSTGRES_USER, POSTGRES_PORT, REDIS_PORT,
# API_PORT, FRONTEND_PORT, NEXT_PUBLIC_API_URL) viven SOLO en el .env de la
# raíz del repo (lo lee docker-compose). Aquí no se duplican.
# =============================================================================

PROJECT_NAME=Backend API
PROJECT_DESCRIPTION=Backend service
APP_VERSION=0.1.0

API_V1_PREFIX=/api/v1

# ENVIRONMENT y LOG_LEVEL aplican al backend cuando corre FUERA de Docker.
# En modo Docker, el compose los sobreescribe con los valores del .env raíz.
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

HOST=0.0.0.0
PORT=8000

# Orígenes permitidos para el frontend (fetch desde el navegador). Lista separada por comas.
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5173,http://[::1]:5173

# Socket.IO valida Origin de forma aparte → sin coincidencia, GET polling con sid responde 400.
# En ENVIRONMENT development y sin esta variable → el servidor usa "*" para Socket.IO.
# Lista explícita: SOCKETIO_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://[::1]:5173
##SOCKETIO_CORS_ORIGINS=

# PostgreSQL — usada al correr fuera de Docker (puerto 5433 para no chocar
# con un Postgres local en 5432). En Docker, el compose sobreescribe
# DATABASE_URL apuntando a postgres:5432 dentro de la red interna.
DATABASE_URL=postgresql+psycopg://app:app@localhost:5433/app
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10

# Redis — usada al correr fuera de Docker (puerto 6380 para no chocar
# con un Redis local en 6379). En Docker, el compose sobreescribe
# REDIS_URL apuntando a redis:6379 dentro de la red interna.
REDIS_URL=redis://localhost:6380/0
SESSION_TTL_SECONDS=86400        # 24h
HISTORY_TTL_SECONDS=604800       # 7 days
HISTORY_MAX_TURNS=40

# LLM (OpenAI). Required
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-5-nano-2025-08-07
OPENAI_TIMEOUT_SECONDS=30
# Optional: override system prompt
# OPENAI_SYSTEM_PROMPT="..."

# Embeddings (OpenAI)
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# Chroma vector store
CHROMA_PERSIST_DIR=.chroma
CHROMA_COLLECTION_KB=grupo_sazon_kb

# RAG retrieval
RAG_TOP_K=4

# Tracing (LangSmith)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=your_langsmith_project