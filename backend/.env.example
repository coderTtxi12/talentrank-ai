PROJECT_NAME=Backend API
PROJECT_DESCRIPTION=Backend service
APP_VERSION=0.1.0

API_V1_PREFIX=/api/v1

ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

HOST=0.0.0.0
PORT=8000

# PostgreSQL (host port 5433 to avoid conflict with a local Postgres on 5432)
DATABASE_URL=postgresql+psycopg://app:app@localhost:5433/app
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10
POSTGRES_PORT=5433

# Redis (host port 6380 to avoid conflict with a local Redis on 6379)
REDIS_URL=redis://localhost:6380/0
REDIS_PORT=6380
SESSION_TTL_SECONDS=86400        # 24h
HISTORY_TTL_SECONDS=604800       # 7 days
