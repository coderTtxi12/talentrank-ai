PROJECT_NAME=Backend API
PROJECT_DESCRIPTION=Backend service
APP_VERSION=0.1.0

API_V1_PREFIX=/api/v1

ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

HOST=0.0.0.0
PORT=8000
# Host port published by docker-compose for the API container.
API_PORT=8000

# PostgreSQL (host port 5433 to avoid conflict with a local Postgres on 5432)
DATABASE_URL=postgresql+psycopg://app:app@localhost:5433/app
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10
POSTGRES_PORT=5433
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
# Note: the api and sentiment-worker containers connect via the compose
# network. docker-compose overrides DATABASE_URL to postgres:5432 and
# REDIS_URL to redis:6379 inside the network, so the localhost values above
# are only used when running the API/worker outside Docker.

# Redis (host port 6380 to avoid conflict with a local Redis on 6379)
REDIS_URL=redis://localhost:6380/0
REDIS_PORT=6380
SESSION_TTL_SECONDS=86400        # 24h
HISTORY_TTL_SECONDS=604800       # 7 days
HISTORY_MAX_TURNS=40

# LLM (OpenAI). Required
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-5-nano-2025-08-07
OPENAI_TIMEOUT_SECONDS=30
# Optional: override system prompt
# OPENAI_SYSTEM_PROMPT="..."

# Embeddings (OpenAI)
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# Chroma vector store
CHROMA_PERSIST_DIR=.chroma
CHROMA_COLLECTION_KB=grupo_sazon_kb

# RAG retrieval
RAG_TOP_K=4

# Tracing (LangSmith)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=your_langsmith_project