# =============================================================================
# Orbio - Variables de orquestación (docker-compose)
# =============================================================================
# Copia este archivo a .env en la raíz del repo:
#     cp .env.example .env
#
# Estas variables sólo configuran cómo Docker Compose levanta los servicios
# (puertos publicados, credenciales de Postgres, etc.). Los secretos de
# aplicación (OPENAI_API_KEY, LANGSMITH_API_KEY, ...) viven en backend/.env.
# =============================================================================

# --- Postgres -----------------------------------------------------------------
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
# Puerto del host (5433 para evitar chocar con un Postgres local en 5432)
POSTGRES_PORT=5433

# --- Redis --------------------------------------------------------------------
# Puerto del host (6380 para evitar chocar con un Redis local en 6379)
REDIS_PORT=6380

# --- API (FastAPI) ------------------------------------------------------------
API_PORT=8000

# --- Frontend (Next.js) -------------------------------------------------------
FRONTEND_PORT=3000
# URL del backend que el navegador del usuario usará. Next.js inlinea esta
# variable en el bundle al hacer `next build`, por eso se pasa como build arg
# en docker-compose.yml. En producción cámbiala por tu dominio público.
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Logging / entorno --------------------------------------------------------
LOG_LEVEL=INFO
ENVIRONMENT=development
